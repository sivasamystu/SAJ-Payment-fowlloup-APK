{
  "hosting": {
    "public": "admin-portal/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "functions": {
      "source": "backend",
      "runtime": "nodejs20"
    }
  }
}