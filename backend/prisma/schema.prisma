datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SubscriptionStatus {
  active
  trial
  suspended
  expired
}

model Company {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  subscriptionStatus SubscriptionStatus @default(trial) @map("sub_status")
  subscriptionPlan   String             @default("basic") @map("sub_plan")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  
  users              User[]
  customers          Customer[]
  surveyWorks        SurveyWork[]
  invoices           Invoice[]
  reminderHistory    ReminderHistory[]
  paymentLogs        PaymentLog[]

  @@map("companies")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  STAFF
}

model User {
  id           String      @id // Firebase UID
  email        String      @unique
  name         String
  role         UserRole    @default(STAFF)
  companyId    String?     @map("company_id") @db.Uuid
  mobileNumber String?     @map("mobile_number")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company      Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  surveyWorks  SurveyWork[]
  remindersTriggered ReminderHistory[]

  @@map("users")
}

model Customer {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  mobile      String
  whatsapp    String
  email       String?
  address     String?
  gstNumber   String?  @map("gst_number")
  companyName String?  @map("company_name")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  surveyWorks SurveyWork[]
  invoices    Invoice[]
  reminderHistories ReminderHistory[]

  @@map("customers")
}

enum WorkStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  BILLED
  PAID
}

model SurveyWork {
  id              String     @id @default(uuid()) @db.Uuid
  companyId       String     @map("company_id") @db.Uuid
  workNumber      String     @unique @map("work_number")
  workDate        DateTime   @map("work_date") @db.Date
  workType        String     @map("work_type")
  siteLocation    String     @map("site_location")
  customerId      String     @map("customer_id") @db.Uuid
  assignedStaffId String?    @map("assigned_staff_id")
  status          WorkStatus @default(NEW)
  completionDate  DateTime?  @map("completion_date") @db.Timestamptz
  remarks         String?
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  assignedStaff   User?      @relation(fields: [assignedStaffId], references: [id], onDelete: SetNull)
  invoices        Invoice[]

  @@map("survey_works")
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  companyId     String        @map("company_id") @db.Uuid
  invoiceNumber String        @unique @map("invoice_number")
  invoiceDate   DateTime      @map("invoice_date") @db.Date
  customerId    String        @map("customer_id") @db.Uuid
  surveyWorkId  String?       @map("survey_work_id") @db.Uuid
  amount        Decimal       @db.Decimal(12, 2)
  gstAmount     Decimal       @default(0.00) @map("gst_amount") @db.Decimal(12, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  dueDate       DateTime      @map("due_date") @db.Date
  status        PaymentStatus @default(PENDING)
  paymentLink   String?       @map("payment_link")
  paymentLinkId String?       @map("payment_link_id")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  surveyWork    SurveyWork?   @relation(fields: [surveyWorkId], references: [id], onDelete: SetNull)
  reminderHistories ReminderHistory[]
  paymentLogs   PaymentLog[]

  @@map("invoices")
}

enum ReminderType {
  PAYMENT_REQUEST
  GENTLE_REMINDER
  PENDING_PAYMENT
  OVERDUE_PAYMENT
  PAYMENT_RECEIVED
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

model ReminderHistory {
  id             String         @id @default(uuid()) @db.Uuid
  companyId      String         @map("company_id") @db.Uuid
  invoiceId      String         @map("invoice_id") @db.Uuid
  customerId     String         @map("customer_id") @db.Uuid
  type           ReminderType
  sentDate       DateTime       @default(now()) @map("sent_date") @db.Timestamptz
  deliveryStatus DeliveryStatus @default(PENDING) @map("delivery_status")
  watiResponse   Json?          @map("wati_response")
  triggeredBy    String?        @map("triggered_by")
  retryCount     Int            @default(0) @map("retry_count")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice        Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  triggeringUser User?          @relation(fields: [triggeredBy], references: [id], onDelete: SetNull)

  @@map("reminder_history")
}

enum PaymentSource {
  WEBHOOK
  MANUAL
}

model PaymentLog {
  id                   String        @id @default(uuid()) @db.Uuid
  companyId            String        @map("company_id") @db.Uuid
  invoiceId            String        @map("invoice_id") @db.Uuid
  amountPaid           Decimal       @map("amount_paid") @db.Decimal(12, 2)
  paymentDate          DateTime      @default(now()) @map("payment_date") @db.Timestamptz
  transactionReference String        @map("transaction_reference")
  source               PaymentSource
  rawPayload           Json?         @map("raw_payload")
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz

  company              Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice              Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payment_logs")
}
